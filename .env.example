# ─────────────────────────────────────────────────────────────
# Frontend (VITE_ prefixed = bundled into public JS — no secrets!)
# ─────────────────────────────────────────────────────────────

# Your Pix key — prefer a "chave aleatória" (random key), not CPF/phone/email.
# It is embedded in every QR by nature, so it is public.
VITE_PIX_KEY=00000000-0000-0000-0000-000000000000

# BR Code required fields. ASCII only, no accents.
# Merchant name <= 25 chars, city <= 15 chars.
VITE_PIX_MERCHANT_NAME=MARIA E JOAO
VITE_PIX_MERCHANT_CITY=SAO PAULO

# Supabase (anon key is public-safe WITH RLS insert-only policy).
VITE_SUPABASE_URL=https://xxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ─────────────────────────────────────────────────────────────
# Serverless only (NEVER VITE_ prefixed — must not reach the browser)
# ─────────────────────────────────────────────────────────────

# Asaas API key. Keep in Vercel env vars only. Rotate immediately if leaked.
ASAAS_API_KEY=your-asaas-api-key

# Asaas base URL — sandbox vs production switch.
# Sandbox:    https://sandbox.asaas.com/api/v3
# Production: https://api.asaas.com/v3
ASAAS_BASE_URL=https://sandbox.asaas.com/api/v3

# Token to validate incoming Asaas webhooks (if you build the webhook).
ASAAS_WEBHOOK_TOKEN=some-long-random-string

# Origin allowed to call the card-checkout function (CORS lock).
ALLOWED_ORIGIN=https://your-site.vercel.app
